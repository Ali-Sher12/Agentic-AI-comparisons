datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model HQ {
  id        String   @id @default(uuid())
  name      String   @unique
  username  String   @unique
  password  String // Hashed password
  createdAt DateTime @default(now())

  // Relations
  uploadedItems Item[] @relation("UploadedBy")
  heldItems     Item[] @relation("HeldAt")
}

model Item {
  id                String   @id @default(uuid())
  size              String
  weight            String
  color             String
  description       String
  numberPlate       String? // Nullable, for transport/vehicles
  condition         String
  recoveredLocation String
  recoveryTime      String // Recovery date & details
  status            String   @default("AVAILABLE") // AVAILABLE, RETURNED
  createdAt         DateTime @default(now())

  // Foreign keys
  uploaderId        String
  holdingLocationId String

  // Relations
  uploader        HQ      @relation("UploadedBy", fields: [uploaderId], references: [id])
  holdingLocation HQ      @relation("HeldAt", fields: [holdingLocationId], references: [id])
  claims          Claim[]

  // Return to Owner metadata (Police-only, invisible to public)
  returnedToName    String?
  returnedToCnic    String?
  returnedToContact String?
  returnedAt        DateTime?
}

model Claim {
  id          String   @id @default(uuid())
  itemId      String
  emailOrCnic String // Combined identifier to enforce 3-claim limit per person
  contactInfo String
  proofPath   String // Relative path to uploaded file (PDF/image)
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())

  // Relations
  item Item @relation(fields: [itemId], references: [id])
}
