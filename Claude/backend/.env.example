# Copy this file to .env and adjust if needed. Defaults work out of the box.

# SQLite database file (relative to /backend)
DATABASE_URL="file:./prisma/dev.db"

# Secret used to sign police login tokens. Change this to any random string.
JWT_SECRET="change-this-to-a-long-random-string-before-real-use"

# How long a police login session stays valid
JWT_EXPIRES_IN="8h"

# Port the backend API listens on
PORT=3001

# Frontend origin allowed to call this API (CORS)
FRONTEND_ORIGIN="http://localhost:5173"

# Max upload size for claim proof-of-ownership documents, in bytes (default 5MB)
MAX_UPLOAD_SIZE_BYTES=5242880
