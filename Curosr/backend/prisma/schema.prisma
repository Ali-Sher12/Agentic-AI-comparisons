generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PoliceHQ {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  username  String      @unique
  password  String
  createdAt DateTime    @default(now())
  items     LostItem[]
}

model LostItem {
  id                    Int       @id @default(autoincrement())
  size                  String
  weight                String
  color                 String
  detailedDescription   String
  numberPlate           String?
  conditionFoundIn      String
  recoveredFromLocation String
  recoveryTimeAndPlace  String
  holdingLocation       String
  uploadDate            DateTime  @default(now())
  returnedToOwner       Boolean   @default(false)
  returnedTo            String?
  returnedAt            DateTime?
  loggedByHQId          Int
  loggedByHQ            PoliceHQ  @relation(fields: [loggedByHQId], references: [id])
  claims                Claim[]
}

model Claim {
  id                  Int       @id @default(autoincrement())
  itemId              Int
  item                LostItem  @relation(fields: [itemId], references: [id])
  identifierType      String
  identifierValue     String
  contactInfo         String
  proofDocumentPath   String
  status              String    @default("pending")
  createdAt           DateTime  @default(now())
  reviewedAt          DateTime?
  reviewedByHQId      Int?
}
